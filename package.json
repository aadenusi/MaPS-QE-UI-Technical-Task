{
  "name": "maps-qe-ui-technical-task",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "npm test",
    "test": "cucumber-js --parallel 0",
    "test:headless": "cross-env HEADLESS=true cucumber-js --parallel 0",
    "test:headed": "cross-env HEADLESS=false cucumber-js --parallel 0",
    "test:report": "cross-env HEADLESS=true cucumber-js --parallel 0 --format progress --format html:reports/cucumber-report.html --format json:reports/cucumber-report.json",
    "test:chrome": "cross-env BROWSER=chromium cucumber-js --parallel 0",
    "test:firefox": "cross-env BROWSER=firefox cucumber-js --parallel 0",
    "test:webkit": "cross-env BROWSER=webkit cucumber-js --parallel 0",
    "test:debug": "cross-env HEADLESS=false SLOW_MO=1000 cucumber-js --parallel 0",
    "test:smoke": "cucumber-js --parallel 0 --tags @smoke",
    "test:regression": "cucumber-js --parallel 0 --tags \"not @smoke\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@cucumber/cucumber": "^12.6.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "playwright": "^1.58.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
